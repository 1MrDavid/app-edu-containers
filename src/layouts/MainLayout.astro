---
import { Terminal } from 'lucide-react';

const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} - Taller de Contenedores</title>
  </head>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">

  <style is:global>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    /* Personalizar scrollbar para que sea minimalista */
    ::-webkit-scrollbar {
      width: 6px;
    }
    ::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 10px;
    }
  </style>
  <body class="bg-slate-50 text-slate-900 flex h-screen overflow-hidden">
    
    <aside class="w-64 bg-slate-900 text-white flex flex-col h-full border-r border-slate-700">
      <div class="p-6 border-b border-slate-800 flex items-center gap-3">
        <Terminal className="text-blue-400" />
        <span class="font-bold text-lg tracking-tight">Docker 101</span>
      </div>
      
      <nav class="flex-1 overflow-y-auto py-4">
        <ul class="space-y-1 px-3">
          <li>
            <a href="/" class="block px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors text-slate-300 hover:text-white">
              Inicio
            </a>
          </li>
          <li class="px-4 py-2 text-xs font-bold text-slate-500 uppercase mt-4">Módulo 1: Fundamentos</li>
          <li>
            <a href="/modulo-1/capas-so" class="block px-4 py-2 rounded-lg bg-blue-600 text-white shadow-md">
              1.1 Capas del SO
            </a>
          </li>
           <li>
            <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800 text-slate-300">
              1.2 VMs vs Contenedores
            </a>
          </li>
        </ul>
      </nav>
      
      <div class="p-4 border-t border-slate-800 text-xs text-slate-500 text-center">
        Universidad [Nombre]
      </div>
    </aside>

    <main class="flex-1 overflow-y-auto p-8 relative">
      <div class="max-w-4xl mx-auto">
        <slot /> </div>
    </main>

  </body>
</html>